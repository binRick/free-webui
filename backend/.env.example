FREE_WEBUI_UPSTREAM_BASE_URL=http://localhost:11434/v1
FREE_WEBUI_UPSTREAM_API_KEY=ollama
FREE_WEBUI_DEFAULT_MODEL=llama3.2
FREE_WEBUI_EMBEDDING_MODEL=nomic-embed-text
FREE_WEBUI_DB_PATH=data/free-webui.db
# Optional: point at any SearXNG instance to enable per-chat web search
# FREE_WEBUI_SEARXNG_URL=http://localhost:8080
# Optional: enable the built-in `imagine` tool. Pick a backend + base URL:
#   openai:        FREE_WEBUI_IMAGE_BASE_URL=https://api.openai.com/v1  FREE_WEBUI_IMAGE_API_KEY=sk-...  FREE_WEBUI_IMAGE_MODEL=dall-e-3
#   automatic1111: FREE_WEBUI_IMAGE_BASE_URL=http://localhost:7860
#   comfyui:       FREE_WEBUI_IMAGE_BASE_URL=http://localhost:8188      FREE_WEBUI_COMFYUI_WORKFLOW_PATH=/path/to/workflow.json
# FREE_WEBUI_IMAGE_BACKEND=openai
# Optional: enable the built-in `run_python` code-interpreter tool.
#   docker     = real sandbox (no network, read-only rootfs, non-root, limits). Preferred.
#   subprocess = same-host child w/ timeouts+rlimits but NO security isolation (trusted use only).
#   auto       = docker if the docker binary is present, else subprocess.
# FREE_WEBUI_CODE_INTERPRETER=docker
# FREE_WEBUI_CODE_DOCKER_IMAGE=python:3-alpine
# FREE_WEBUI_CODE_TIMEOUT_SECONDS=15
# FREE_WEBUI_SECRET_KEY=set-me-in-prod  (otherwise auto-generated at data/secret.key)
FREE_WEBUI_ALLOWED_ORIGINS=["http://localhost:5173"]
