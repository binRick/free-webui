FREE_WEBUI_UPSTREAM_BASE_URL=http://localhost:11434/v1
FREE_WEBUI_UPSTREAM_API_KEY=ollama
FREE_WEBUI_DEFAULT_MODEL=llama3.2
FREE_WEBUI_EMBEDDING_MODEL=nomic-embed-text
FREE_WEBUI_DB_PATH=data/free-webui.db
# Default instance display name (branding). An admin can override it + set
# site-wide custom CSS at runtime via /admin/appearance.
# FREE_WEBUI_INSTANCE_NAME=free-webui
# Optional: point at any SearXNG instance to enable per-chat web search
# FREE_WEBUI_SEARXNG_URL=http://localhost:8080
# RAG URL loader: timeout (s) for fetching a pasted URL (web page / PDF / text)
# to ingest as a document. The fetch is SSRF-guarded and capped at
# FREE_WEBUI_RAG_MAX_UPLOAD_BYTES; tune the SSRF_* knobs to reach a LAN host.
# FREE_WEBUI_URL_FETCH_TIMEOUT_SECONDS=15
# Optional: enable the built-in `imagine` tool. Pick a backend + base URL:
#   openai:        FREE_WEBUI_IMAGE_BASE_URL=https://api.openai.com/v1  FREE_WEBUI_IMAGE_API_KEY=sk-...  FREE_WEBUI_IMAGE_MODEL=dall-e-3
#   automatic1111: FREE_WEBUI_IMAGE_BASE_URL=http://localhost:7860
#   comfyui:       FREE_WEBUI_IMAGE_BASE_URL=http://localhost:8188      FREE_WEBUI_COMFYUI_WORKFLOW_PATH=/path/to/workflow.json
# FREE_WEBUI_IMAGE_BACKEND=openai
# Optional: enable the built-in `run_python` code-interpreter tool.
#   docker     = real sandbox (no network, read-only rootfs, non-root, limits). Preferred.
#   subprocess = same-host child w/ timeouts+rlimits but NO security isolation (trusted use only).
#   auto       = docker if the docker binary is present, else subprocess.
# FREE_WEBUI_CODE_INTERPRETER=docker
# FREE_WEBUI_CODE_DOCKER_IMAGE=python:3-alpine
# FREE_WEBUI_CODE_TIMEOUT_SECONDS=15
# Optional: enable the pipelines/plugin framework. Point at a directory of
# operator-installed *.py modules exposing async inlet(body,ctx)/outlet(text,ctx)
# hooks. TRUSTED in-process code with full backend access — load only files you
# wrote or audited. See backend/example_plugins/clamp_and_redact.py.
# FREE_WEBUI_PLUGINS_DIR=backend/example_plugins
# FREE_WEBUI_PLUGINS_TIMEOUT_SECONDS=5
# FREE_WEBUI_SECRET_KEY=set-me-in-prod  (otherwise auto-generated at data/secret.key)
FREE_WEBUI_ALLOWED_ORIGINS=["http://localhost:5173"]
#
# --- Security hardening (sensible defaults; tighten for production) ---
# Send the session cookie's Secure flag (set true when served over HTTPS).
# FREE_WEBUI_COOKIE_SECURE=false
# Emit Strict-Transport-Security (only meaningful behind HTTPS).
# FREE_WEBUI_SECURITY_HSTS=false
# Login throttle: max attempts per (IP, username) per window; 0 disables.
# FREE_WEBUI_LOGIN_RATE_LIMIT=10
# FREE_WEBUI_LOGIN_RATE_WINDOW_SECONDS=60
# SSRF guard for user/operator URLs (MCP servers, image result URLs). Block
# private+loopback by default; allowlist trusted hosts/CIDRs to permit a local
# MCP server, e.g. FREE_WEBUI_SSRF_ALLOW_HOSTS=["127.0.0.1","10.0.0.0/8"].
# FREE_WEBUI_SSRF_PROTECTION=true
# FREE_WEBUI_SSRF_BLOCK_PRIVATE=true
# FREE_WEBUI_SSRF_ALLOW_HOSTS=[]
# Reject request bodies larger than this many bytes (0 disables).
# FREE_WEBUI_MAX_REQUEST_BODY_BYTES=33554432
# Max gap (seconds) between upstream tokens before a stalled stream is aborted.
# FREE_WEBUI_UPSTREAM_READ_TIMEOUT_SECONDS=300
#
# --- Context budgeting (bound what is replayed upstream every turn) ---
# Keep only the most recent N user/assistant turns (0 = unlimited). Generous
# ceiling; lower it for small-context models. The system prompt + injected
# RAG/web/memory context are always kept on top of these.
# FREE_WEBUI_MAX_CONTEXT_MESSAGES=100
# Additionally drop the oldest of those turns until history fits ~this many
# tokens (rough chars/4 estimate). 0 = off (rely on the message cap alone).
# FREE_WEBUI_MAX_CONTEXT_TOKENS=0
# Cap how many persistent memories are injected per turn, most recent first.
# FREE_WEBUI_MAX_MEMORY_ITEMS=100
#
# --- OIDC / SSO (set issuer + client_id + client_secret to enable) ---
# redirect_uri must point at this backend's /api/auth/oidc/callback. Works
# cleanly behind a single origin (frontend + /api on the same host) in prod.
# FREE_WEBUI_OIDC_ISSUER=https://accounts.google.com
# FREE_WEBUI_OIDC_CLIENT_ID=...
# FREE_WEBUI_OIDC_CLIENT_SECRET=...
# FREE_WEBUI_OIDC_REDIRECT_URI=https://chat.example.com/api/auth/oidc/callback
# FREE_WEBUI_OIDC_PROVIDER_NAME=Google
# FREE_WEBUI_OIDC_SCOPES=openid email profile
# FREE_WEBUI_OIDC_ALLOW_SIGNUP=true
# FREE_WEBUI_OIDC_ADMIN_EMAILS=["you@example.com"]
# FREE_WEBUI_OIDC_POST_LOGIN_REDIRECT=/
# In split dev (SPA :5173, API :8000) set this to http://localhost:5173/ so the
# browser lands back on the SPA after the callback. OIDC endpoints must be https
# unless FREE_WEBUI_OIDC_INSECURE_TRANSPORT=true (local testing only).
# FREE_WEBUI_OIDC_INSECURE_TRANSPORT=false
