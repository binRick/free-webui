# Optional overrides for the integration harness. Copy to `.env` to customize.
# Compose reads `.env` automatically when you run from this directory.
#
# Defaults are small + CPU-friendly + tool-capable. First run pulls ~1.3 GB into
# the `ollama-models` named volume; subsequent runs reuse the cache.

# Chat model (must be tool-capable for the tool-loop test to fire; the test
# soft-skips when the model doesn't call the tool, so smaller models still pass).
MODEL=qwen2.5:1.5b

# Embedding model used by the RAG path (free-webui's default).
EMBED_MODEL=nomic-embed-text
